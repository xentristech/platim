# =====================================================================
# PLATIM — Configuración Apache / LiteSpeed (Hostinger)
# =====================================================================

# Codificación por defecto
AddDefaultCharset UTF-8

# Página de error 404 personalizada
ErrorDocument 404 /404.html

# ---------------------------------------------------------------------
# Reescritura de URLs
# ---------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) Forzar HTTPS + www (https://www.platim.co) en un solo salto
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^ https://www.platim.co%{REQUEST_URI} [L,R=301]

  # 2) /index.html (o /index) -> raíz "/"
  RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
  RewriteRule ^ / [R=301,L]

  # 3) Redirige de /pagina.html a /pagina (URL limpia, una sola versión)
  RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # 4) Sirve internamente /pagina como /pagina.html
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^([^\.]+)$ $1.html [NC,L]
</IfModule>

# ---------------------------------------------------------------------
# Compresión GZIP
# ---------------------------------------------------------------------
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript text/javascript
  AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
</IfModule>

# ---------------------------------------------------------------------
# Caché del navegador (mejora velocidad y Core Web Vitals)
# ---------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/x-icon      "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType text/css          "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html         "access plus 0 seconds"
</IfModule>

# ---------------------------------------------------------------------
# Seguridad básica
# ---------------------------------------------------------------------
# Evitar listado de directorios
Options -Indexes

# Bloquear acceso a archivos sensibles
<FilesMatch "\.(htaccess|zip)$">
  Require all denied
</FilesMatch>
